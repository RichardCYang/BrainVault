# Keep committed lockfiles portable across developer and CI environments.
registry=https://registry.npmjs.org/
replace-registry-host=always

# Bound network retry time so an unreachable registry fails clearly instead of
# appearing to loop forever.
fetch-retries=2
fetch-retry-factor=2
fetch-retry-mintimeout=1000
fetch-retry-maxtimeout=10000
fetch-timeout=60000
