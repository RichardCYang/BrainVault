NODE_ENV=development
PORT=4000
DATABASE_URL="mariadb://brainvault:brainvault_password@127.0.0.1:3306/brainvault"
# Optional. If set, server startup and npm run db:init can create the database/user with admin privileges.
# MARIADB_ADMIN_URL="mariadb://root:your-root-password@127.0.0.1:3306"
AUTO_BOOTSTRAP_DATABASE=true
DATABASE_CONNECTION_LIMIT=10
JWT_SECRET="replace-this-with-a-long-random-secret-before-sharing"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:4000,http://127.0.0.1:4000,http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173"
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# OpenGraph bookmark preview requests are fetched by the server with strict time and response-size limits.
BOOKMARK_FETCH_TIMEOUT_MS=8000
BOOKMARK_FETCH_MAX_BYTES=524288

# Attachment files are stored outside the public web root and downloaded through an authenticated route.
ATTACHMENT_UPLOAD_DIR="uploads"
MAX_ATTACHMENT_SIZE_MB=25
